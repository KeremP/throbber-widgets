{
  "name": "throbber-widgets",
  "version": "0.1.0",
  "description": "Lightweight React throbber/spinner components using Unicode characters",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "react",
    "spinner",
    "throbber",
    "loading",
    "loader",
    "progress",
    "indicator",
    "unicode",
    "braille",
    "animation",
    "cli",
    "terminal",
    "ink",
    "tui",
    "async",
    "suspense",
    "component"
  ],
  "license": "MIT",
  "author": "Kyle J Ryan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kylejryan/throbber-widgets.git"
  },
  "homepage": "https://github.com/kylejryan/throbber-widgets#readme",
  "bugs": {
    "url": "https://github.com/kylejryan/throbber-widgets/issues"
  }
}
